\pard\qc\fs22\b APPENDIX A - CODING\par
\pard\fs18
Place code snippets, setup commands, and example SQL here. Example SQL to create behavior_logs:\par
\par
CREATE TABLE IF NOT EXISTS behavior_logs (\par
    id INT AUTO_INCREMENT PRIMARY KEY,\par
    timestamp DOUBLE,\par
    event_type VARCHAR(50),\par
    hashed_event TEXT,\par
    raw_data JSON,\par
    prediction INT,\par
    processed_at TIMESTAMP NULL,\par
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\par
);\par

}
